# Server
PORT=3000
NODE_ENV=development

# Tenant resolution: strip this from Host to get subdomain (e.g. acfc.localhost:3000 → acfc)
TENANT_HOST_SUFFIX=localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sportbooker
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Pool config (optional) – max connections, timeouts
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MILLIS=10000
DB_POOL_CONNECTION_TIMEOUT_MILLIS=5000
DB_STATEMENT_TIMEOUT_MILLIS=30000

# JWT access token – short-lived, used for API auth
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# Public origins (no path, no trailing slash). API defaults to http://localhost:PORT.
API_PUBLIC_ORIGIN=http://localhost:3000
WEB_APP_PUBLIC_ORIGIN=http://localhost:5173

# Ziina – per-tenant access tokens are stored in the tenants table (DB), encrypted with this key.
# Generate with: openssl rand -hex 32
ZIINA_ENCRYPTION_KEY=replace_with_64_hex_chars

# Optional S3 upload storage. Leave empty to keep local disk uploads.
S3_BUCKET_NAME=
S3_REGION=

# Resend – API key and From address for transactional email (verify domain in Resend dashboard)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@example.com
EMAIL_APP_NAME=SportBooker
EMAIL_SUPPORT_EMAIL=support@example.com
EMAIL_WAITLIST_REFUND_ETA=3-5 business days
RESEND_TEMPLATE_PASSWORD_RESET_ID=432bfd62-0d5e-48cf-ad61-fd3d782b6698
RESEND_TEMPLATE_EMAIL_VERIFICATION_ID=672a13df-d7f1-499e-9449-d55fb02d26a8
RESEND_TEMPLATE_WAITLIST_EXPIRED_REFUND_ID=e464ed47-8960-4722-b2a1-0e2667813de1

# Optional. Min 32 chars. In production, enables /api/docs + /api/docs-json and protects them with Bearer auth (for Orval CI).
OPENAPI_DOCS_TOKEN=

# Comma-separated allowed browser origins for CORS. Empty = no CORS.
# Tenant subdomains (*.TENANT_HOST_SUFFIX) are allowed dynamically — no need to list them here.
CORS_ORIGINS=http://localhost:5173,https://app.sportbooker.net